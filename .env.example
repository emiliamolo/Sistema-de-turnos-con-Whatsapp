# ============================================================
# Turnos API - Environment Configuration Template
# Copy this to .env and fill in your actual values
# ============================================================

# ==================== DATABASE ====================
DATABASE_URL=postgresql://user_admin:password_123@localhost:5432/turnos_db
# For Docker: postgresql://user_admin:password_123@db:5432/turnos_db

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379/0
# For Docker: redis://redis:6379/0

# ==================== SECURITY ====================
# CRITICAL: Change these in production!
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== AI (GEMINI) ====================
# Get your free API key at: https://aistudio.google.com/apikey
# Optional: if not set, the bot will use exact text matching (no AI)
GEMINI_API_KEY=your-gemini-api-key

# ==================== WHATSAPP ====================
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token-change-in-production
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=your-access-token-from-meta
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-from-meta

# ==================== APPLICATION ====================
PROJECT_NAME=Turnos
ENVIRONMENT=development
# ENVIRONMENT=production

# ==================== ADMIN SETUP ====================
# Set to False in production after initial setup
CREATE_DEFAULT_SUPERADMIN=True
SUPERADMIN_EMAIL=admin@turnos.io
SUPERADMIN_PASSWORD=admin123
# WARNING: Change SUPERADMIN_PASSWORD immediately after first login!

# ==================== POSTGRES (for docker-compose) ====================
POSTGRES_USER=user_admin
POSTGRES_PASSWORD=password_123
POSTGRES_DB=turnos_db
